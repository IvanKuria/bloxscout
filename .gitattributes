# Normalize line endings to LF on checkout across platforms.
# Without this, Windows runners (and contributors) get CRLF, which trips
# biome's formatter and produces spurious lint failures in CI.
* text=auto eol=lf

# Binary files — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.sqlite binary
*.db binary
*.woff binary
*.woff2 binary
