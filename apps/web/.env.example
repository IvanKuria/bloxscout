# =============================================================================
# bloxscout web app — environment variables
# Copy to `.env.local` and fill in. None of these are committed.
# The build (`next build`) is designed to succeed WITHOUT these set; they are
# only required at runtime for auth + billing to actually function.
# =============================================================================

# --- Site -------------------------------------------------------------------
# Absolute origin of this deployment. Used to build Stripe redirect URLs and
# the Supabase auth callback. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---------------------------------------------------------------
# Project URL + anon (publishable) key — safe to expose to the browser.
# Dashboard: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role (secret) key — SERVER ONLY. Bypasses RLS. Used by the Stripe
# webhook to upsert subscription rows. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe -----------------------------------------------------------------
# Secret key (sk_test_... / sk_live_...). Dashboard: Developers -> API keys
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Webhook signing secret (whsec_...). Created when you add the webhook endpoint
# (Developers -> Webhooks) OR printed by `stripe listen` during local dev.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Stripe price IDs (one per tier x billing interval) ---------------------
# Create products + recurring prices in Stripe, then paste the price IDs
# (price_...) here. The tier->price map lives in lib/stripe/config.ts.
# Pro: ~$19/mo / ~$190/yr. Studio is "coming soon" — leave its vars unset.
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_pro_yearly
# NEXT_PUBLIC_STRIPE_PRICE_STUDIO_MONTHLY=  (deferred)
# NEXT_PUBLIC_STRIPE_PRICE_STUDIO_YEARLY=   (deferred)

# --- Discord OAuth ----------------------------------------------------------
# Discord is the ONLY sign-in method. Create an app at
# https://discord.com/developers and add the OAuth2 redirect URL for your env:
#   local stack:  http://127.0.0.1:54321/auth/v1/callback
#   hosted:       https://YOUR-PROJECT-ref.supabase.co/auth/v1/callback
#
# LOCAL stack: the Supabase CLI reads the client id/secret from these env vars
# (referenced by supabase/config.toml) at `supabase start`:
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=your-discord-client-id
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=your-discord-client-secret
# HOSTED: enter the same client id/secret in the Supabase dashboard instead
# (Authentication -> Providers -> Discord).

# --- PostHog analytics ------------------------------------------------------
# Product analytics + session replay. The phc_ project token is browser-safe
# (it is a publishable ingestion key, not a secret). Grab it from
# Project Settings -> API in your PostHog project. Events post through the
# /ingest reverse proxy wired up in next.config.ts. All PostHog code no-ops
# gracefully when these are unset, so `next build` still succeeds without them.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
