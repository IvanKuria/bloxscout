{
  "name": "bloxscout",
  "version": "0.0.1",
  "description": "Reconnaissance for Roblox game devs and their agents — open-source MCP server + CLI for Roblox game analytics.",
  "author": "Ivan Kuria <ivankuria7@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/IvanKuria/bloxscout",
  "bugs": {
    "url": "https://github.com/IvanKuria/bloxscout/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanKuria/bloxscout.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "roblox",
    "roblox-api",
    "cli",
    "analytics",
    "game-analytics",
    "claude",
    "cursor",
    "llm",
    "agent"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bloxscout": "dist/cli.js",
    "bloxscout-mcp": "dist/mcp.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION=1 vitest run test/integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "lru-cache": "^11.0.2",
    "undici": "^8.3.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
